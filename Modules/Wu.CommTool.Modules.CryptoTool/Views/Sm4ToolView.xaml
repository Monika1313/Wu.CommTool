<UserControl x:Class="Wu.CommTool.Modules.CryptoTool.Views.Sm4ToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:enums="clr-namespace:Wu.CommTool.Modules.CryptoTool.Enums"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:wu="https://github.com/Monika1313/Wu"
             d:DesignHeight="450"
             d:DesignWidth="800"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,8"
                   Style="{StaticResource TitleTextBlock}"
                   Text="SM4 &#x52A0;&#x89E3;&#x5BC6;" />

        <WrapPanel Grid.Row="1"
                   Margin="0,0,0,8"
                   VerticalAlignment="Center">
            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x5BC6;&#x94A5;" />
            <TextBox MinWidth="220"
                     Margin="0,0,12,0"
                     Text="{Binding KeyText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x504F;&#x79FB;&#x91CF;" />
            <TextBox Width="220"
                     IsEnabled="{Binding IsIvEnabled}"
                     Text="{Binding IvText, UpdateSourceTrigger=PropertyChanged}" />
        </WrapPanel>

        <WrapPanel Grid.Row="2"
                   Margin="0,0,0,8"
                   VerticalAlignment="Center">
            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x6A21;&#x5F0F;" />
            <ComboBox Width="auto"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding CipherModes}"
                      SelectedItem="{Binding SelectedCipherMode}" />

            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x586B;&#x5145;" />
            <ComboBox Width="auto"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding PaddingModes}"
                      SelectedItem="{Binding SelectedPaddingMode}" />

            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x5BC6;&#x94A5;&#x683C;&#x5F0F;" />
            <ComboBox Width="auto"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding Source={wu:EnumBindingSource {x:Type enums:KeyFormat}}}"
                      SelectedItem="{Binding SelectedKeyFormat}" />

            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x660E;&#x6587;&#x683C;&#x5F0F;" />
            <ComboBox Width="auto"
                      Margin="0,0,12,0"
                      ItemsSource="{Binding PlainFormats}"
                      SelectedItem="{Binding SelectedPlainFormat}" />

            <TextBlock Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Text="&#x5BC6;&#x6587;&#x683C;&#x5F0F;" />
            <ComboBox Width="auto"
                      ItemsSource="{Binding CipherFormats}"
                      SelectedItem="{Binding SelectedCipherFormat}" />
        </WrapPanel>

        <TextBox Grid.Row="3"
                 AcceptsReturn="True"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <WrapPanel Grid.Row="4"
                   Margin="0,8"
                   HorizontalAlignment="Center">
            <Button Width="90"
                    Margin="4"
                    Command="{Binding EncryptCommand}"
                    Content="&#x52A0;&#x5BC6;" />
            <Button Width="90"
                    Margin="4"
                    Command="{Binding DecryptCommand}"
                    Content="&#x89E3;&#x5BC6;" />
            <Button Width="90"
                    Margin="4"
                    Command="{Binding SwapCommand}"
                    Content="&#x4EA4;&#x6362;" />
            <Button Width="90"
                    Margin="4"
                    Command="{Binding ClearCommand}"
                    Content="&#x6E05;&#x7A7A;" />
            <Button Width="100"
                    Margin="4"
                    Command="{Binding ImportConfigCommand}"
                    Content="&#x5BFC;&#x5165;&#x914D;&#x7F6E;" />
            <Button Width="100"
                    Margin="4"
                    Command="{Binding ExportConfigCommand}"
                    Content="&#x5BFC;&#x51FA;&#x914D;&#x7F6E;" />
        </WrapPanel>

        <TextBox Grid.Row="5"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 Text="{Binding OutputText}"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
    </Grid>
</UserControl>
